@startuml
skinparam monochrome true
skinparam shadowing false

participant Seed
participant Noise
participant Orbit
participant Bloom
participant Render

Seed -> Noise : lock seed
Noise -> Orbit : vector drift
Orbit -> Bloom : trail stack
Bloom -> Render : glow map
Render -> Seed : reseed
Render -> Orbit : pulse
@enduml
